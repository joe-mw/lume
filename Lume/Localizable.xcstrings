          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cambiare playlist modifica i contenuti mostrati in Home, Film, Serie e TV in diretta."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "プレイリストを切り替えると、ホーム、映画、シリーズ、ライブTV全体に表示されるコンテンツが変わります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "재생목록을 전환하면 홈, 영화, 시리즈, 라이브 TV 전반에 표시되는 콘텐츠가 변경됩니다."
          }
        },
        "pt" : {
          "stringUnit" : {
