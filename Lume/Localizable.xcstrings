    "Move up or down to position, then select to place. Press Menu to cancel." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nach oben oder unten bewegen, dann zum Platzieren auswählen. Menü-Taste drücken zum Abbrechen."
          }
