          "stringUnit" : {
            "state" : "translated",
            "value" : "Downloads"
          }
        }
      }
    },
    "Drag to reorder your favorite channels — this sets the order shown in the Favorites category. Tap the heart to remove one. Reset restores the provider's order." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ziehe, um deine Favoritensender neu anzuordnen – das bestimmt ihre Reihenfolge in der Favoriten-Kategorie. Tippe auf das Herz, um einen zu entfernen. Zurücksetzen stellt die Reihenfolge des Anbieters wieder her."
          }
        }
      }
    },
    "Drop Late Frames" : {
      "comment" : "A toggle to drop late frames",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
