    "Download movies and episodes for offline playback. Auto-delete removes the file once you've finished watching." : {
      "comment" : "A description of the download settings in the settings screen.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lade Filme und Folgen für die Offline-Wiedergabe herunter. Die automatische Löschfunktion entfernt die Datei, sobald du sie vollständig angesehen hast."
          }
        }
      }
    },
    "Downloaded movies and episodes appear here for offline viewing." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Heruntergeladene Filme und Folgen erscheinen hier für die Offline-Wiedergabe."
          }
        }
      }
    },
    "Downloading playlist" : {
      "comment" : "Title of a sync step for importing playlists.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wiedergabeliste wird geladen"
