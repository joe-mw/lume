<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Shared App Store export options for Lume.
  Reused verbatim for every platform (iOS / tvOS / macOS / visionOS) — the
  platform is chosen by the archive's `-destination`, not by this file.
  Automatic signing matches the project's CODE_SIGN_STYLE = Automatic; on CI
  pass -allowProvisioningUpdates + an App Store Connect API key to archive AND
  exportArchive (see .claude/skills/app-store-submission/references/guide.md).
-->
<plist version="1.0">
<dict>
    <key>method</key>
    <string>app-store-connect</string>
    <key>destination</key>
    <string>export</string>
    <key>teamID</key>
    <string>CHG45F8MCL</string>
    <key>signingStyle</key>
    <string>automatic</string>
    <key>uploadSymbols</key>
    <true/>
    <key>manageAppVersionAndBuildNumber</key>
    <false/>
</dict>
</plist>
